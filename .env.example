# Database
DATABASE_URL=postgresql://ballistic:ballistic_secret@localhost:5432/ballistic_sim
REDIS_URL=redis://localhost:6379/0

# OpenWeatherMap API
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Gemini AI API
GEMINI_API_KEY=your_gemini_api_key_here

# Airflow
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://ballistic:ballistic_secret@postgres:5432/ballistic_sim
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql+psycopg2://ballistic:ballistic_secret@postgres:5432/ballistic_sim
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
AIRFLOW__CORE__FERNET_KEY=generate_a_fernet_key
AIRFLOW__WEBSERVER__SECRET_KEY=generate_a_secret_key